{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* 신규 TS 파일에만 적용되는 엄격 모드 — 기존 JS는 검사하지 않음 */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* 기존 .jsx 코드와 공존: JS 허용하되 타입 검사는 안 함 */
    "allowJs": true,
    "checkJs": false,

    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src"]
}
